@page "/appointments"
@inject DataService DataService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Список записів</PageTitle>

<h1>Список записів</h1>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(isSuccessMessage ? "alert-success" : "alert-info")">@statusMessage</div>
}

@if (Appointments.Count == 0)
{
    <div class="empty-state">Записів ще немає. Створіть перший запис через сторінку бронювання.</div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Ім'я клієнта</th>
                <th>Лікар</th>
                <th>Послуга</th>
                <th>Дата</th>
                <th>Час</th>
                <th>Статус</th>
                <th>Оплата</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appointment in Appointments)
            {
                <tr>
                    <td>
                        <strong>@appointment.Name</strong><br />
                        <small>@appointment.Email</small>
                    </td>
                    <td>@appointment.DoctorName</td>
                    <td>@appointment.Service</td>
                    <td>@appointment.Date.ToString("dd.MM.yyyy")</td>
                    <td>@appointment.Time</td>
                    <td>@GetStatusText(appointment.Status)</td>
                    <td>@(appointment.Paid ? "Сплачено" : $"{appointment.Price.ToString("0.##")} грн")</td>
                    <td>
                        @if (appointment.Status == AppointmentStatuses.Upcoming)
                        {
                            <button class="btn btn-success me-2" @onclick="() => UpdateStatus(appointment.Id, AppointmentStatuses.Completed)">Завершити</button>
                        }
                        <button class="btn btn-secondary me-2" @onclick="() => TogglePaid(appointment.Id)">
                            @(appointment.Paid ? "Скасувати оплату" : "Оплатити")
                        </button>
                        <button class="btn btn-danger" @onclick="() => DeleteAppointment(appointment.Id)">Видалити</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/booking")'>Додати запис</button>

@code {
    private List<Appointment> Appointments = new();
    private string? statusMessage;
    private bool isSuccessMessage;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("message", out var message)
            && string.Equals(message.ToString(), "created", StringComparison.OrdinalIgnoreCase))
        {
            statusMessage = "Запис успішно створено. Тепер його можна завершити, оплатити або видалити.";
            isSuccessMessage = true;
        }

        LoadAppointments();
    }

    private void LoadAppointments()
    {
        Appointments = DataService.GetAppointments();
    }

    private void UpdateStatus(int id, string status)
    {
        DataService.UpdateAppointmentStatus(id, status);
        LoadAppointments();
        statusMessage = "Прийом позначено як завершений.";
        isSuccessMessage = true;
    }

    private void TogglePaid(int id)
    {
        var appointment = Appointments.FirstOrDefault(item => item.Id == id);
        DataService.TogglePaid(id);
        LoadAppointments();
        if (appointment is not null)
        {
            statusMessage = appointment.Paid
                ? "Оплату скасовано. Запис знову позначено як не сплачений."
                : "Оплату підтверджено успішно.";
            isSuccessMessage = true;
        }
    }

    private static string GetStatusText(string status) => status switch
    {
        AppointmentStatuses.Completed => "Завершено",
        AppointmentStatuses.Missed => "Пропущено",
        AppointmentStatuses.Cancelled => "Скасовано",
        _ => "Активний"
    };

    private void DeleteAppointment(int id)
    {
        DataService.DeleteAppointment(id);
        LoadAppointments();
        statusMessage = "Запис видалено.";
        isSuccessMessage = true;
    }
}