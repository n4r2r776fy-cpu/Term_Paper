@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using MyBlazorApp.Models
@implements IDisposable
@page "/booking"
@inject DataService DataService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Запис на прийом</PageTitle>

@if (!AuthService.IsInitialized)
{
    <p>Завантаження профілю...</p>
}
else if (!AuthService.IsLoggedIn)
{
    <p>Будь ласка, <a href="/login">увійдіть</a> або <a href="/register">зареєструйтесь</a>, щоб записатися на прийом.</p>
}
else
{
    <h1>Записатися на прийом</h1>

    @if (!string.IsNullOrWhiteSpace(submissionError))
    {
        <div class="alert alert-danger">@submissionError</div>
    }

    <EditForm Model="@appointment" OnValidSubmit="@(_ => HandleValidSubmit())">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label for="name">Ім'я:</label>
            <InputText id="name" @bind-Value="appointment.Name" class="form-control" />
        </div>

        <div class="form-group">
            <label for="email">Email:</label>
            <InputText id="email" @bind-Value="appointment.Email" class="form-control" />
        </div>

        <div class="form-group">
            <label for="phone">Телефон:</label>
            <InputText id="phone" @bind-Value="appointment.Phone" class="form-control" />
        </div>

        <div class="form-group">
            <label for="doctor">Лікар:</label>
            <InputSelect id="doctor" Value="appointment.DoctorName" ValueChanged="@((string value) => OnDoctorChanged(value))" ValueExpression="@(() => appointment.DoctorName)" class="form-control">
                <option value="">Виберіть лікаря</option>
                @foreach (var doctor in doctors)
                {
                    <option value="@doctor.Name">@doctor.Name (@doctor.Specialty)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => appointment.DoctorName)" />
        </div>

        <div class="form-group">
            <label for="service">Послуга:</label>
            <InputSelect id="service" @bind-Value="appointment.Service" class="form-control">
                <option value="">@(availableServices.Count == 0 ? "Спочатку виберіть лікаря" : "Виберіть послугу")</option>
                @foreach (var service in availableServices)
                {
                    <option value="@service">@service</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => appointment.Service)" />
        </div>

        <div class="form-group">
            <label for="date">Дата:</label>
            <InputDate id="date" Value="appointment.Date" ValueChanged="@((DateTime value) => OnDateChanged(value))" ValueExpression="@(() => appointment.Date)" class="form-control" />
            <ValidationMessage For="@(() => appointment.Date)" />
        </div>

        <div class="form-group">
            <label for="time">Час:</label>
            <InputSelect id="time" @bind-Value="appointment.Time" class="form-control" disabled="@(availableTimeSlots.Count == 0)">
                <option value="">@(availableTimeSlots.Count == 0 ? "Немає вільних слотів" : "Виберіть час")</option>
                @foreach (var timeSlot in availableTimeSlots)
                {
                    <option value="@timeSlot">@timeSlot</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => appointment.Time)" />
            @if (!string.IsNullOrWhiteSpace(slotMessage))
            {
                <small class="text-muted">@slotMessage</small>
            }
        </div>

        <button type="submit" class="btn btn-primary">Записатися</button>
    </EditForm>
}

@code {
    private Appointment appointment = new();
    private IReadOnlyList<Doctor> doctors = Array.Empty<Doctor>();
    private IReadOnlyList<string> availableServices = Array.Empty<string>();
    private IReadOnlyList<string> availableTimeSlots = Array.Empty<string>();
    private string? submissionError;
    private string? slotMessage;

    protected override void OnInitialized()
    {
        AuthService.OnChange += HandleAuthChanged;
        doctors = DataService.GetDoctors();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("doctor", out var doctor))
        {
            appointment.DoctorName = doctor.ToString();
        }

        PopulateUserData();
        RefreshBookingOptions();
    }

    private void PopulateUserData()
    {
        if (AuthService.IsLoggedIn)
        {
            appointment.Name = AuthService.CurrentUser!.Name;
            appointment.Email = AuthService.CurrentUser.Email;
        }
    }

    private void HandleAuthChanged()
    {
        PopulateUserData();
        RefreshBookingOptions();
        InvokeAsync(StateHasChanged);
    }

    private Task OnDoctorChanged(string doctorName)
    {
        appointment.DoctorName = doctorName;
        RefreshBookingOptions();
        return Task.CompletedTask;
    }

    private Task OnDateChanged(DateTime date)
    {
        appointment.Date = date;
        RefreshBookingOptions();
        return Task.CompletedTask;
    }

    private void RefreshBookingOptions()
    {
        availableServices = DataService.GetServicesForDoctor(appointment.DoctorName);
        if (!availableServices.Contains(appointment.Service ?? string.Empty, StringComparer.OrdinalIgnoreCase))
        {
            appointment.Service = availableServices.Count == 1 ? availableServices[0] : null;
        }

        availableTimeSlots = DataService.GetAvailableTimeSlots(appointment.DoctorName, appointment.Date);
        if (!availableTimeSlots.Contains(appointment.Time, StringComparer.OrdinalIgnoreCase))
        {
            appointment.Time = string.Empty;
        }

        slotMessage = string.IsNullOrWhiteSpace(appointment.DoctorName)
            ? "Спочатку виберіть лікаря, щоб побачити доступний час."
            : availableTimeSlots.Count == 0
                ? "На обрану дату немає вільних слотів. Спробуйте іншу дату."
                : $"Доступно слотів: {availableTimeSlots.Count}.";
    }

    public void Dispose()
    {
        AuthService.OnChange -= HandleAuthChanged;
    }

    private Task HandleValidSubmit()
    {
        if (!AuthService.IsLoggedIn)
        {
            return Task.CompletedTask;
        }

        appointment.UserEmail = AuthService.CurrentUser!.Email;
        appointment.Status = AppointmentStatuses.Upcoming;
        submissionError = null;

        try
        {
            DataService.SaveAppointment(appointment);
            Navigation.NavigateTo("/appointments?message=created");
        }
        catch (InvalidOperationException ex)
        {
            RefreshBookingOptions();
            submissionError = ex.Message;
        }

        return Task.CompletedTask;
    }
}