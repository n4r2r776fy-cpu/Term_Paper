@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using MyBlazorApp.Models
@implements IDisposable
@page "/booking"
@inject DataService DataService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Запис на прийом</PageTitle>

@if (!AuthService.IsInitialized)
{
    <p>Завантаження профілю...</p>
}
else if (!AuthService.IsLoggedIn)
{
    <p>Будь ласка, <a href="/login">увійдіть</a> або <a href="/register">зареєструйтесь</a>, щоб записатися на прийом.</p>
}
else
{
    <h1>Записатися на прийом</h1>

    <EditForm Model="@appointment" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label for="name">Ім'я:</label>
            <InputText id="name" @bind-Value="appointment.Name" class="form-control" />
        </div>

        <div class="form-group">
            <label for="email">Email:</label>
            <InputText id="email" @bind-Value="appointment.Email" class="form-control" />
        </div>

        <div class="form-group">
            <label for="phone">Телефон:</label>
            <InputText id="phone" @bind-Value="appointment.Phone" class="form-control" />
        </div>

        <div class="form-group">
            <label for="doctor">Лікар:</label>
            <InputSelect id="doctor" @bind-Value="appointment.DoctorName" class="form-control">
                <option value="">Виберіть лікаря</option>
                @foreach (var doctor in doctors)
                {
                    <option value="@doctor.Name">@doctor.Name (@doctor.Specialty)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => appointment.DoctorName)" />
        </div>

        <div class="form-group">
            <label for="service">Послуга:</label>
            <InputSelect id="service" @bind-Value="appointment.Service" class="form-control">
                <option value="">Виберіть послугу</option>
                <option value="Терапевтична консультація">Терапевтична консультація</option>
                <option value="Стоматологічний огляд">Стоматологічний огляд</option>
                <option value="Дерматологічна консультація">Дерматологічна консультація</option>
            </InputSelect>
            <ValidationMessage For="@(() => appointment.Service)" />
        </div>

        <div class="form-group">
            <label for="date">Дата:</label>
            <InputDate id="date" @bind-Value="appointment.Date" class="form-control" />
        </div>

        <div class="form-group">
            <label for="time">Час:</label>
            <InputText id="time" @bind-Value="appointment.Time" class="form-control" type="time" />
        </div>

        <button type="submit" class="btn btn-primary">Записатися</button>
    </EditForm>
}

@code {
    private Appointment appointment = new();
    private IReadOnlyList<Doctor> doctors = Array.Empty<Doctor>();

    protected override void OnInitialized()
    {
        AuthService.OnChange += HandleAuthChanged;
        doctors = DataService.GetDoctors();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("doctor", out var doctor))
        {
            appointment.DoctorName = doctor.ToString();
        }

        PopulateUserData();
    }

    private void PopulateUserData()
    {
        if (AuthService.IsLoggedIn)
        {
            appointment.Name = AuthService.CurrentUser!.Name;
            appointment.Email = AuthService.CurrentUser.Email;
        }
    }

    private void HandleAuthChanged()
    {
        PopulateUserData();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthService.OnChange -= HandleAuthChanged;
    }

    private void HandleValidSubmit()
    {
        if (!AuthService.IsLoggedIn)
        {
            return;
        }

        appointment.UserEmail = AuthService.CurrentUser!.Email;
        appointment.Status = AppointmentStatuses.Upcoming;
        DataService.SaveAppointment(appointment);
        Navigation.NavigateTo("/appointments?message=created");
    }
}