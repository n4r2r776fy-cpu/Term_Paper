@page "/checkout"
@inject DataService DataService

<PageTitle>Оплата</PageTitle>

<h2>Оплата записів</h2>

<div class="checkout-list">
    @if (items.Count == 0)
    {
        <div class="checkout-card small">
            <div class="empty-state">Немає записів для відображення.</div>
        </div>
    }
    else
    {
        @foreach (var item in items)
        {
            <div class="checkout-card small">
                <div class="checkout-row">
                    <div>
                        <div class="c-name">@item.Name</div>
                        <div class="c-sub">@item.DoctorName · @item.Service</div>
                    </div>
                    <div class="c-right">
                        <div class="amount">@item.Price.ToString("0.##") грн</div>
                        <div class="status">@(item.Paid ? "Сплачено" : "Не сплачено")</div>
                    </div>
                </div>
                <div class="checkout-actions">
                    <button class="btn primary" @onclick="() => TogglePaid(item.Id)">@((item.Paid) ? "Позначити як не сплачено" : "Позначити як сплачено")</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Appointment> items = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        items = DataService.GetAppointments()
            .Where(a => a.Status != AppointmentStatuses.Cancelled)
            .OrderBy(a => a.Paid)
            .ThenByDescending(a => a.Date)
            .ToList();
    }

    private void TogglePaid(int id)
    {
        DataService.TogglePaid(id);
        LoadData();
    }
}
