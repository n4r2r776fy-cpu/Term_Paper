@page "/checkout"
@inject MyBlazorApp.Services.DataService DataService

<PageTitle>Checkout</PageTitle>

<h2>Checkout</h2>

<div class="checkout-list">
    @foreach (var item in items)
    {
        <div class="checkout-card small">
            <div class="checkout-row">
                <div>
                    <div class="c-name">@item.Name</div>
                    <div class="c-sub">@item.Details</div>
                </div>
                <div class="c-right">
                    <div class="amount">$@item.Amount</div>
                    <div class="status">@(item.Paid ? "Paid" : "Not Paid")</div>
                </div>
            </div>
            <div class="checkout-actions">
                <button class="btn primary" @onclick="() => TogglePaid(item)">@((item.Paid) ? "Mark Unpaid" : "Mark Paid")</button>
            </div>
        </div>
    }
</div>

@code {
    private List<CheckoutItem> items = new()
    {
        new CheckoutItem("Huisan Li", "Consultation + meds", 37.05m, false),
        new CheckoutItem("Joe White", "Consultation + meds", 34.05m, true),
    };

    private void TogglePaid(CheckoutItem i) => i.Paid = !i.Paid;

    private class CheckoutItem
    {
        public string Name { get; }
        public string Details { get; }
        public decimal Amount { get; }
        public bool Paid { get; set; }
        public CheckoutItem(string name, string details, decimal amount, bool paid)
        {
            Name = name; Details = details; Amount = amount; Paid = paid;
        }
    }
}
