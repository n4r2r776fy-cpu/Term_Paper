@page "/doctors"
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject DataService DataService

<PageTitle>Лікарі</PageTitle>

<h2>Лікарі</h2>

<div class="doctors-list">
    @foreach (var d in doctors)
    {
        <div class="doctor-card small">
            <div class="doctor-header">
                <img src="@d.AvatarPath" alt="@d.Name" />
                <div>
                    <div class="name">@d.Name</div>
                    <div class="doctor-specialty">@d.Specialty</div>
                    <div class="status">@GetStatus(d.Name)</div>
                </div>
            </div>
            <div class="patient-box">
                @if (GetNextAppointment(d.Name) is Appointment nextAppointment)
                {
                    <div class="patient-name">Пацієнт: @nextAppointment.Name</div>
                    <div class="patient-details">@nextAppointment.Service · @nextAppointment.Date.ToString("dd.MM.yyyy") @nextAppointment.Time</div>
                }
                else
                {
                    <div class="patient-name">Найближчих записів немає</div>
                }
            </div>
            <div class="doctor-actions">
                <button class="btn action" @onclick="() => StartConsultation(d.Name)">Записатися до лікаря</button>
            </div>
        </div>
    }
</div>

@code {
    private IReadOnlyList<Doctor> doctors = Array.Empty<Doctor>();
    private List<Appointment> appointments = new();

    protected override void OnInitialized()
    {
        doctors = DataService.GetDoctors();
        appointments = DataService.GetAppointments();
    }

    private string GetStatus(string doctorName) => GetNextAppointment(doctorName) is null
        ? "Вільний"
        : "Має запланований прийом";

    private Appointment? GetNextAppointment(string doctorName) => appointments
        .Where(a => a.Status != AppointmentStatuses.Cancelled && a.Date.Date >= DateTime.Today)
        .FirstOrDefault(a => string.Equals(a.DoctorName, doctorName, StringComparison.OrdinalIgnoreCase));

    private void StartConsultation(string doctorName)
    {
        if (!AuthService.IsLoggedIn)
        {
            var returnUrl = Uri.EscapeDataString($"/booking?doctor={Uri.EscapeDataString(doctorName)}");
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        Navigation.NavigateTo($"/booking?doctor={Uri.EscapeDataString(doctorName)}");
    }
}
