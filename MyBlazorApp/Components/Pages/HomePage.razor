@page "/"
@page "/homepage"
@inject DataService DataService
@inject NavigationManager Navigation
@inject AuthService AuthService

<PageTitle>Головна</PageTitle>

<link href="css/HomePage.css" rel="stylesheet" />

<div class="dashboard-intro">
    <div>
        <h1>Керування записами клініки</h1>
        <p>Нові бронювання, статуси черги та стан оплат одразу відображаються на всіх сторінках сайту.</p>
    </div>
    @if (!AuthService.IsLoggedIn)
    {
        <div class="demo-credentials">
            <div><strong>Демо вхід:</strong> demo@clinic.local</div>
            <div><strong>Пароль:</strong> demo123</div>
        </div>
    }
</div>

<div class="dashboard">
    <div class="dashboard-left">
        <section class="section doctors">
            <div class="section-header-row">
                <div>
                    <h2>Лікарі</h2>
                    <div class="section-subtitle">Реальні записи по лікарях</div>
                </div>
                <button class="btn action" @onclick='() => Navigation.NavigateTo("/doctors")'>Усі лікарі</button>
            </div>

            <div class="cards-row wrap-cards">
                @foreach (var doctor in doctors)
                {
                    var nextAppointment = GetNextAppointmentForDoctor(doctor.Name);
                    <div class="doctor-card">
                        <div class="doctor-header">
                            <img src="@doctor.AvatarPath" alt="@doctor.Name" />
                            <div class="doctor-meta">
                                <div class="name">@doctor.Name</div>
                                <div class="doctor-specialty">@doctor.Specialty</div>
                                <div class="status">@(nextAppointment is null ? "Вільний" : $"Наступний прийом о {nextAppointment.Time}")</div>
                            </div>
                        </div>
                        <div class="patient-box">
                            @if (nextAppointment is null)
                            {
                                <div class="patient-name">Немає активних записів</div>
                            }
                            else
                            {
                                <div class="patient-name">@nextAppointment.Name</div>
                                <div class="patient-details">@nextAppointment.Service · @nextAppointment.Date.ToString("dd.MM.yyyy")</div>
                            }
                            <button class="btn action" @onclick='() => OpenBooking(doctor.Name)'>Записатися</button>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="section queue">
            <div class="section-header-row">
                <div>
                    <h2>Черга</h2>
                    <div class="section-subtitle">Найближчі прийоми</div>
                </div>
                <button class="btn primary" @onclick='() => Navigation.NavigateTo("/queue")'>Відкрити чергу</button>
            </div>

            <div class="queue-box">
                <div class="queue-tabs">
                    <button class="tab @(showMissedQueue ? string.Empty : "active")" @onclick="() => ShowQueue(false)">Upcoming <span class="badge">@upcomingAppointments.Count</span></button>
                    <button class="tab @(showMissedQueue ? "active" : string.Empty)" @onclick="() => ShowQueue(true)">Missed <span class="badge">@missedAppointments.Count</span></button>
                </div>

                <div class="queue-cards column-list">
                    @if (VisibleQueueAppointments.Count == 0)
                    {
                        <div class="empty-state">@(showMissedQueue ? "Немає пропущених записів." : "Поки що немає активних записів.")</div>
                    }
                    else
                    {
                        @foreach (var item in VisibleQueueAppointments.Take(4).Select((appointment, index) => new { appointment, index }))
                        {
                            <div class="queue-card">
                                <div class="q-left">
                                    <div class="avatar small">@item.appointment.Name[..1]</div>
                                    <div class="q-meta">
                                        <div class="q-name">@item.appointment.Name</div>
                                        <div class="q-sub">@item.appointment.DoctorName · @item.appointment.Date.ToString("dd.MM") · @item.appointment.Time</div>
                                    </div>
                                </div>
                                <div class="q-right compact-right">
                                    <div class="q-number">#@(item.index + 1)</div>
                                    @if (showMissedQueue)
                                    {
                                        <button class="btn action" @onclick='() => OpenBooking(item.appointment.DoctorName)'>Записатися знову</button>
                                    }
                                    else
                                    {
                                        <button class="btn danger" @onclick='() => RemoveAppointment(item.appointment.Id)'>Скасувати</button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </section>
    </div>

    <aside class="dashboard-right">
        <section class="section checkout">
            <div class="section-header-row">
                <div>
                    <h2>Оплата</h2>
                    <div class="section-subtitle">Останні рахунки</div>
                </div>
            </div>

            @if (checkoutAppointments.Count == 0)
            {
                <div class="checkout-card">
                    <div class="empty-state">Немає записів для оплати.</div>
                </div>
            }
            else
            {
                @foreach (var appointment in checkoutAppointments)
                {
                    <div class="checkout-card">
                        <div class="checkout-item">
                            <div class="c-avatar">@appointment.Name[..1]</div>
                            <div class="c-meta">
                                <div class="c-name">@appointment.Name</div>
                                <div class="c-info">@appointment.Service · @appointment.Price.ToString("0.##") грн</div>
                            </div>
                        </div>
                        <button class="btn primary" @onclick='() => TogglePaid(appointment.Id)'>@(appointment.Paid ? "Позначити як не сплачено" : "Позначити як сплачено")</button>
                    </div>
                }
            }
        </section>
    </aside>
</div>

@code {
    private IReadOnlyList<Doctor> doctors = Array.Empty<Doctor>();
    private List<Appointment> upcomingAppointments = new();
    private List<Appointment> missedAppointments = new();
    private List<Appointment> checkoutAppointments = new();
    private bool showMissedQueue;

    private IReadOnlyList<Appointment> VisibleQueueAppointments => showMissedQueue
        ? missedAppointments
        : upcomingAppointments;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        var appointments = DataService.GetAppointments();
        doctors = DataService.GetDoctors();
        upcomingAppointments = appointments
            .Where(a => a.Status != AppointmentStatuses.Cancelled && a.Date.Date >= DateTime.Today)
            .ToList();
        missedAppointments = appointments
            .Where(a => a.Status == AppointmentStatuses.Missed || a.Date.Date < DateTime.Today)
            .ToList();
        checkoutAppointments = appointments
            .Where(a => a.Status != AppointmentStatuses.Cancelled)
            .OrderBy(a => a.Paid)
            .ThenByDescending(a => a.CreatedAt)
            .Take(3)
            .ToList();
    }

    private Appointment? GetNextAppointmentForDoctor(string doctorName) => upcomingAppointments
        .FirstOrDefault(a => string.Equals(a.DoctorName, doctorName, StringComparison.OrdinalIgnoreCase));

    private void OpenBooking(string doctorName)
    {
        if (!AuthService.IsLoggedIn)
        {
            var returnUrl = Uri.EscapeDataString($"/booking?doctor={Uri.EscapeDataString(doctorName)}");
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        Navigation.NavigateTo($"/booking?doctor={Uri.EscapeDataString(doctorName)}");
    }

    private void RemoveAppointment(int id)
    {
        DataService.DeleteAppointment(id);
        LoadData();
    }

    private void TogglePaid(int id)
    {
        DataService.TogglePaid(id);
        LoadData();
    }

    private void ShowQueue(bool showMissed)
    {
        showMissedQueue = showMissed;
    }
}