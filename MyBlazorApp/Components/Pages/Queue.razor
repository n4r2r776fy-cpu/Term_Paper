@page "/queue"
@inject DataService DataService

<PageTitle>Черга</PageTitle>

<h2>Черга записів</h2>

<div class="queue-controls">
    <input placeholder="Search in queue..." @bind="search" />
    <div class="tabs">
        <button class="tab @(showMissed ? "" : "active")" @onclick="() => ToggleTab(false)">Upcoming (@upcomingCount)</button>
        <button class="tab @(showMissed ? "active" : "")" @onclick="() => ToggleTab(true)">Missed (@missedCount)</button>
    </div>
</div>

<div class="queue-list">
    @if (!filtered.Any())
    {
        <div class="empty-state">Немає записів для вибраного фільтра.</div>
    }
    else
    {
        @foreach (var item in filtered.Select((appointment, index) => new { appointment, index }))
        {
            <div class="queue-card">
                <div>
                    <div class="q-name">#@(item.index + 1) · @item.appointment.Name</div>
                    <div class="q-sub">@item.appointment.DoctorName · @item.appointment.Service · @item.appointment.Date.ToString("dd.MM.yyyy") @item.appointment.Time</div>
                </div>
                <div class="q-actions">
                    <button class="btn danger" @onclick="() => Cancel(item.appointment.Id)">Видалити</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private string search = string.Empty;
    private bool showMissed = false;
    private List<Appointment> all = new();
    private int upcomingCount;
    private int missedCount;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private IEnumerable<Appointment> filtered => all
        .Where(a => showMissed ? IsMissed(a) : IsUpcoming(a))
        .Where(a => string.IsNullOrWhiteSpace(search)
            || a.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
            || a.DoctorName.Contains(search, StringComparison.OrdinalIgnoreCase)
            || (a.Service?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false));

    private void LoadData()
    {
        all = DataService.GetAppointments();
        upcomingCount = all.Count(IsUpcoming);
        missedCount = all.Count(IsMissed);
    }

    private static bool IsUpcoming(Appointment appointment) =>
        appointment.Status != AppointmentStatuses.Cancelled
        && appointment.Status != AppointmentStatuses.Missed
        && appointment.Date.Date >= DateTime.Today;

    private static bool IsMissed(Appointment appointment) =>
        appointment.Status == AppointmentStatuses.Missed
        || (appointment.Status != AppointmentStatuses.Cancelled && appointment.Date.Date < DateTime.Today);

    private void ToggleTab(bool missed)
    {
        showMissed = missed;
    }

    private void Cancel(int id)
    {
        DataService.DeleteAppointment(id);
        LoadData();
    }
}
