@page "/register"
@using MyBlazorApp.Models
@using MyBlazorApp.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Реєстрація</PageTitle>

<h1>Реєстрація</h1>

@if (!AuthService.IsInitialized)
{
    <p>Завантаження стану авторизації...</p>
}
else
{
    <EditForm Model="@user" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label for="name">Ім'я:</label>
            <InputText id="name" @bind-Value="user.Name" class="form-control" />
        </div>

        <div class="form-group">
            <label for="email">Email:</label>
            <InputText id="email" @bind-Value="user.Email" class="form-control" />
        </div>

        <div class="form-group">
            <label for="password">Пароль:</label>
            <InputText id="password" @bind-Value="user.Password" class="form-control" type="password" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-2">@errorMessage</div>
        }

        <button type="submit" class="btn btn-primary mt-3">Зареєструватися</button>
    </EditForm>
}

@code {
    private User user = new();
    private string? errorMessage;

    private async Task HandleRegister()
    {
        errorMessage = null;
        if (await AuthService.RegisterAsync(user))
        {
            if (await AuthService.LoginAsync(user.Email, user.Password))
            {
                Navigation.NavigateTo("/homepage");
            }
            else
            {
                errorMessage = "Не вдалося увійти після реєстрації.";
            }
        }
        else
        {
            errorMessage = "Користувач з таким email вже існує.";
        }
    }
}